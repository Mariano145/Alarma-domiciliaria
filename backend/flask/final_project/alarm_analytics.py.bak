from __future__ import annotations

from abc import ABC, abstractmethod
from collections import Counter
from datetime import datetime, timedelta
from typing import List


class AnalyticsService():


    def __init__(self, algorithms: list[AnalyticsAlgorithm]) -> None:

        self.algorithms = algorithms


    def calculate_metrics(self, events)-> dict:
        results={}
        for algorithm in self.algorithms:
            metrics = algorithm.process(events)
            results.update(metrics)

        return results



class AnalyticsAlgorithm(ABC):

    @abstractmethod
    def process(self, events: list[Event])->dict:
        pass



class WindowedCountsAlgorithm(AnalyticsAlgorithm):
    def process(self, events: list[Event])->dict:
        if not events:
            return{}
        #Time anchor method
        most_recent_time = max(event.timestamp for event in events)
        limit_time = most_recent_time - timedelta(minutes=10)

        #Event time filter
        windowed_events = [e for e in events if e.timestamp >= limit_time]

        #Event type filter
        counts = Counter(e.type for e in windowed_events)

        return dict(counts)



class PinFailHysteresisAlgorithm(AnalyticsAlgorithm):
    def process(self, events: list[Event])->dict:
        if not events:
            return{"pin_fail_suspicious": False}
        #Ensure temporal order
        sorted_events = sorted(events, key=lambda e: e.timestamp)
        consecutive_fails= 0
        alert_active = False
        for event in sorted_events:
            if event.type == "PIN_ATTEMPT":
                if event.value == "FAIL":
                    consecutive_fails += 1
                    if consecutive_fails >= 3:
                        alert_active = True
                elif event.value == "SUCCESS": # Corregido typo "SUCCES"
                    consecutive_fails = 0
                    alert_active = False
        return {"pin_fail_suspicious": alert_active}


class DoorOpenAnomalyAlgorithm(AnalyticsAlgorithm):
    def process(self, events: list[Event])->dict:
        if not events:
            return {"door_open_anomaly": False}

        most_recent_time = max(event.timestamp for event in events)
        limit_time = most_recent_time - timedelta(minutes=10)

        door_open_events = [
            e for e in events
            if e.timestamp >= limit_time
            and e.type == "DOOR_STATE_CHANGED"
             and e.value == "OPEN"
        ]

        is_anomaly = len(door_open_events) > 6

        return {"door_open_anomaly": is_anomaly}
